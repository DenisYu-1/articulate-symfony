{
    "name": "denisyu-1/articulate-symfony",
    "description": "Symfony bundle integration for the Articulate context-bounded ORM",
    "type": "symfony-bundle",
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "Articulate\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Articulate\\Symfony\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "denisyu-1/articulate": "^1.1.0",
        "psr/container": "^2.0",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/cache": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
